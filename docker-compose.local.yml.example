services:
  easydash:
    build:
      context: .
      dockerfile: Dockerfile
    image: easydash:local
    container_name: easydash_local
    restart: unless-stopped
    ports:
      - "3000:3000"
    volumes:
      - easydash_push_data:/app/data
    environment:
      - NODE_ENV=production
      # VAPID keys — copy from .env or generate new ones:
      # node -e "const wp=require('web-push'); console.log(JSON.stringify(wp.generateVAPIDKeys()))"
      - VAPID_PUBLIC_KEY=${VAPID_PUBLIC_KEY}
      - VAPID_PRIVATE_KEY=${VAPID_PRIVATE_KEY}
      - VAPID_SUBJECT=${VAPID_SUBJECT:-mailto:admin@easydash.local}

volumes:
  easydash_push_data:
