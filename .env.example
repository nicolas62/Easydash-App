# Copy this file to .env and fill in your values
# NEVER commit .env — it contains secrets

# VAPID keys for Web Push notifications
# Generate new keys: node -e "const wp=require('web-push'); console.log(JSON.stringify(wp.generateVAPIDKeys()))"
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@easydash.local

# Optional: restrict push broadcast endpoint to a specific origin
# PUSH_ALLOWED_ORIGIN=https://your-domain.com
