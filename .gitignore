# Dependencies
node_modules/

# Build outputs
dist/
dist-server/

# Environment variables — NEVER commit secrets
.env
.env.local
.env.*.local
# .env.production est commité volontairement : ne contient que des clés
# Google publiques (VITE_*) restreintes par domaine dans Google Cloud Console.
# Ne jamais y mettre de secrets serveur (VAPID, PUSH_SECRET, etc.)
.env.development

# Docker local overrides — contain secrets (VAPID keys, etc.)
docker-compose.local.yml

# Data / runtime
data/

# Logs
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/settings.json
.idea/

# Claude agent workspace
.agent/
